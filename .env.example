# Environment Variables for Receipt Agent
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# API Tokens
API_TOKEN=your_api_token_here
OPENAI_API_KEY=your_openai_api_key_here

# Google Services
SPREADSHEET_ID=your_google_sheets_id
DRIVE_FOLDER_ID=your_drive_folder_id
DRIVE_DELETED_FOLDER_ID=your_deleted_folder_id
AUDIT_LOG_FOLDER_ID=your_audit_log_folder_id

# GAS Script ID (for clasp)
SCRIPT_ID=your_gas_script_id

# Note: In GAS, use Script Properties instead of .env for server-side secrets
# This file is for local development reference only